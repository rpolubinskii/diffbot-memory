# Copy to .env. Consumed by the diffbot-memory service (src/diffbot_memory/server.py).

# Ollama on the 3090 host (OpenAI-compatible). Ollama must listen on 0.0.0.0
# (OLLAMA_HOST=0.0.0.0:11434) so the container can reach it via host.docker.internal.
OPENAI_API_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama

# Extraction LLM (chat-completions) and embedder, pulled in Ollama first. Use an
# Ollama-native model that supports tools/structured output (e.g. official gemma4),
# NOT an imported HF gemma4 GGUF (llama.cpp lacks the arch -> "unknown architecture").
MODEL_NAME=gemma4:26b
EMBEDDER_MODEL=bge-m3
EMBEDDER_DIM=1024

# One graph namespace for the robot; must match diffbot-mcp's configured group.
GRAPHITI_GROUP_ID=diffbot

# FalkorDB (the falkordb service in this compose).
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
FALKORDB_DATABASE=default_db

# MCP server bind + concurrency (keep low: one local model).
MCP_HOST=0.0.0.0
MCP_PORT=8100
SEMAPHORE_LIMIT=2
