# Copy to .env. Values feed docker-compose.yml and config.yaml (${VAR} expansion).

# Ollama on the 3090 host (OpenAI-compatible endpoint) for both LLM and embeddings.
OPENAI_API_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama

# Extraction LLM and embedder (must be pulled in Ollama first).
MODEL_NAME=hf.co/unsloth/gemma-4-31B-it-GGUF:IQ4_XS
EMBEDDER_MODEL=bge-m3

# One graph namespace for the robot. Must match diffbot-mcp's configured group_id.
GRAPHITI_GROUP_ID=diffbot

# Keep low: one local model can't service many concurrent extractions without thrashing.
SEMAPHORE_LIMIT=2

# FalkorDB lives in the same container.
FALKORDB_URI=redis://localhost:6379
FALKORDB_DATABASE=default_db
BROWSER=1
